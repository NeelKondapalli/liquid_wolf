# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/

# production
build/
dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Secrets & private env files ─────────────────────────────
# Root .env (Supabase keys, API secrets)
.env
# Local override files (may contain real keys)
.env.local
.env*.local

# Claude settings (local only)
.claude/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Supabase service role key (never commit)
# Use: export SUPABASE_SERVICE_ROLE_KEY='...' in your shell

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE
.idea/
.vscode/
*.swp
*.swo
