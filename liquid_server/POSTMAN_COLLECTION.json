      "item": [
        {
          "name": "Get Markets",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"{{phone_number}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/market/markets",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "market", "markets"]
            }
          }
        },
